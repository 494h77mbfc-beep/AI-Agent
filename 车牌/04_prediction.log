. * Collect test period t values
. qui levelsof t if test==1, local(test_ts)

. di "Test t values: `test_ts'"
Test t values: 190 191 192 193 194

. 
. *===========================================================================
. * SECTION 1 – Models with warning_price (train & !anomaly, 2014+)
. *===========================================================================
. 
. *---------------------------------------------------------------------------
. * MA4: Level min_price  supply bidders warning_price t i.month L1_min
. *---------------------------------------------------------------------------
. capture drop p0 e0

. 
. qui reg min_price supply bidders warning_price t i.month L1_min ///
>     if train==1 & anomaly==0

. qui predict p0

. qui gen e0 = min_price - p0

. 
. scalar mae_MA4  = 0

. scalar sse_MA4  = 0

. scalar mape_MA4 = 0

. scalar cnt_MA4  = 0

. 
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     local p = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     local a = r(mean)
  6.     local e = `a' - `p'
  7.     local ae = abs(`e')
  8.     local pe = abs(`e'/`a')*100
  9.     qui sum year if t==`tv'
 10.     local yr = r(mean)
 11.     qui sum month if t==`tv'
 12.     local mo = r(mean)
 13.     scalar mae_MA4  = mae_MA4  + `ae'
 14.     scalar sse_MA4  = sse_MA4  + (`e')^2
 15.     scalar mape_MA4 = mape_MA4 + `pe'
 16.     scalar cnt_MA4  = cnt_MA4  + 1
 17.     file write fout "MA4" _tab "min_price" _tab "level" _tab "`yr'" _tab "
> `mo'" ///
>         _tab "`a'" _tab %8.1f (`p') _tab %8.1f (`e') _tab %8.1f (`ae') _tab %
> 6.2f (`pe') _n
 18. }

. scalar mae_MA4  = mae_MA4  / cnt_MA4

. scalar rmse_MA4 = sqrt(sse_MA4 / cnt_MA4)

. scalar mape_MA4 = mape_MA4 / cnt_MA4

. di "MA4: MAE=" mae_MA4 "  RMSE=" rmse_MA4 "  MAPE=" mape_MA4
MA4: MAE=638.26563  RMSE=686.71331  MAPE=.68030569

. 
. * Save per-period predictions for the detailed table
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     scalar pred_MA4_`tv' = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     scalar act_min_`tv' = r(mean)
  6.     qui sum year if t==`tv'
  7.     scalar yr_`tv' = r(mean)
  8.     qui sum month if t==`tv'
  9.     scalar mo_`tv' = r(mean)
 10. }

. 
. drop p0 e0

. 
. *---------------------------------------------------------------------------
. * MB4: Log min_price  ln_supply ln_bidders ln_warning t i.month L1_ln_min
. *---------------------------------------------------------------------------
. capture drop plog p0 e0

. 
. qui reg ln_min_price ln_supply ln_bidders ln_warning t i.month L1_ln_min ///
>     if train==1 & anomaly==0

. local sigma2_MB4 = e(rmse)^2

. qui predict plog

. qui gen p0 = exp(plog + `sigma2_MB4'/2)

. qui gen e0 = min_price - p0

. 
. scalar mae_MB4  = 0

. scalar sse_MB4  = 0

. scalar mape_MB4 = 0

. scalar cnt_MB4  = 0

. 
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     local p = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     local a = r(mean)
  6.     local e = `a' - `p'
  7.     local ae = abs(`e')
  8.     local pe = abs(`e'/`a')*100
  9.     qui sum year if t==`tv'
 10.     local yr = r(mean)
 11.     qui sum month if t==`tv'
 12.     local mo = r(mean)
 13.     scalar mae_MB4  = mae_MB4  + `ae'
 14.     scalar sse_MB4  = sse_MB4  + (`e')^2
 15.     scalar mape_MB4 = mape_MB4 + `pe'
 16.     scalar cnt_MB4  = cnt_MB4  + 1
 17.     file write fout "MB4" _tab "min_price" _tab "log->level" _tab "`yr'" _
> tab "`mo'" ///
>         _tab "`a'" _tab %8.1f (`p') _tab %8.1f (`e') _tab %8.1f (`ae') _tab %
> 6.2f (`pe') _n
 18. }

. scalar mae_MB4  = mae_MB4  / cnt_MB4

. scalar rmse_MB4 = sqrt(sse_MB4 / cnt_MB4)

. scalar mape_MB4 = mape_MB4 / cnt_MB4

. di "MB4: MAE=" mae_MB4 "  RMSE=" rmse_MB4 "  MAPE=" mape_MB4
MB4: MAE=640.74531  RMSE=683.77109  MAPE=.68279012

. 
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     scalar pred_MB4_`tv' = r(mean)
  4. }

. 
. drop plog p0 e0

