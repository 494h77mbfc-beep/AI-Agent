. do 04_prediction.do 

. /*===========================================================================
>   04_prediction.do
>   Out-of-Sample Prediction and Evaluation
>   Models: MA4, MB4, MC4, MD4 (with warning_price)
>           FA4, FB4, FC4, FD4 (full sample, no warning_price)
> ===========================================================================*/
. 
. clear all

. set more off

. capture log close

. cd "/home/aragorn/Working/chepai_data"
/home/aragorn/Working/chepai_data

. use "data/cleaned_data.dta", clear

. capture mkdir "results"

. capture mkdir "log"

. log using "log/04_prediction.log", replace text
