. *---------------------------------------------------------------------------
. * 8. DEFINE TIME AXIS LABELS
. *---------------------------------------------------------------------------
. * t is numeric 1-194; map January of each year to a label
. label define tlab ///
>     1   "2010" ///
>     13  "2011" ///
>     25  "2012" ///
>     37  "2013" ///
>     49  "2014" ///
>     61  "2015" ///
>     73  "2016" ///
>     85  "2017" ///
>     97  "2018" ///
>     109 "2019" ///
>     121 "2020" ///
>     133 "2021" ///
>     145 "2022" ///
>     157 "2023" ///
>     169 "2024" ///
>     181 "2025" ///
>     194 "2026m2"

. label values t tlab

. 
. * Train/test boundary: last train obs is 2025m9 = t=189 (1+(2025-2010)*12+9-1
> =188... let's calc)
. * t = (year-2010)*12 + month  → 2025m9: (2025-2010)*12 + 9 = 180+9 = 189
. * first test obs: 2025m10 → t = 190
. local split_t = 189

. 
