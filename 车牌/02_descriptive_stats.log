. else {
.     * Fallback: use file write
.     file open fh using "results/desc_stats.txt", write replace
.     file write fh "Descriptive Statistics - Full Sample" _n
.     file write fh "==========================================================
> ===========" _n
.     file write fh "Variable            Mean          SD           Min        
>   Max         N" _n
.     file write fh "----------------------------------------------------------
> -----------" _n
.     foreach v in min_price avg_price supply bidders warning_price bid_ratio p
> rice_spread {
  2.         quietly sum `v' if !anomaly
  3.         file write fh %-20s ("`v'") %12.1f (r(mean)) %12.1f (r(sd)) %12.0f
>  (r(min)) %12.0f (r(max)) %8.0f (r(N)) _n
  4.     }
.     file write fh "==========================================================
> ===========" _n
.     file close fh
.     di "Descriptive stats written via file write (estout not available)."
. }

