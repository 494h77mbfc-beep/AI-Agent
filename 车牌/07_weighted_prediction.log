. *===========================================================================
. * SECTION 1 – Weighted WLS Models (analytic weight = t)
. *===========================================================================
. 
. *---------------------------------------------------------------------------
. * WA4: Level min_price  [aw=t]
. *---------------------------------------------------------------------------
. capture drop p0 e0

. 
. qui reg min_price supply bidders warning_price t i.month L1_min [aw=t] if tra
> in==1 & anomaly==0

. qui predict p0

. qui gen e0 = min_price - p0

. 
. scalar mae_WA4  = 0

. scalar sse_WA4  = 0

. scalar mape_WA4 = 0

. scalar cnt_WA4  = 0

. 
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     local p = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     local a = r(mean)
  6.     local e = `a' - `p'
  7.     local ae = abs(`e')
  8.     local pe = abs(`e'/`a')*100
  9.     scalar mae_WA4  = mae_WA4  + `ae'
 10.     scalar sse_WA4  = sse_WA4  + (`e')^2
 11.     scalar mape_WA4 = mape_WA4 + `pe'
 12.     scalar cnt_WA4  = cnt_WA4  + 1
 13. }

. scalar mae_WA4  = mae_WA4  / cnt_WA4

. scalar rmse_WA4 = sqrt(sse_WA4 / cnt_WA4)

. scalar mape_WA4 = mape_WA4 / cnt_WA4

. di "WA4: MAE=" mae_WA4 "  RMSE=" rmse_WA4 "  MAPE=" mape_WA4
WA4: MAE=547.82969  RMSE=590.55121  MAPE=.58383436

. 
. * Save per-period predictions
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     scalar pred_WA4_`tv' = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     scalar act_min_`tv' = r(mean)
  6.     qui sum year if t==`tv'
  7.     scalar yr_`tv' = r(mean)
  8.     qui sum month if t==`tv'
  9.     scalar mo_`tv' = r(mean)
 10. }

. 
. drop p0 e0

. 
. *---------------------------------------------------------------------------
. * WB4: Log min_price  [aw=t] — Duan smearing adjustment
. *---------------------------------------------------------------------------
. capture drop plog p0 e0

. 
. qui reg ln_min_price ln_supply ln_bidders ln_warning t i.month L1_ln_min [aw=
> t] if train==1 & anomaly==0

. local sigma2_WB4 = e(rmse)^2

. qui predict plog

. qui gen p0 = exp(plog + `sigma2_WB4'/2)

. qui gen e0 = min_price - p0

. 
. scalar mae_WB4  = 0

. scalar sse_WB4  = 0

. scalar mape_WB4 = 0

. scalar cnt_WB4  = 0

. 
. foreach tv of local test_ts {
  2.     qui sum p0 if t==`tv'
  3.     local p = r(mean)
  4.     qui sum min_price if t==`tv'
  5.     local a = r(mean)
  6.     local e = `a' - `p'
  7.     local ae = abs(`e')
  8.     local pe = abs(`e'/`a')*100
  9.     scalar mae_WB4  = mae_WB4  + `ae'
 10.     scalar sse_WB4  = sse_WB4  + (`e')^2
 11.     scalar mape_WB4 = mape_WB4 + `pe'
 12.     scalar cnt_WB4  = cnt_WB4  + 1
 13. }

. scalar mae_WB4  = mae_WB4  / cnt_WB4

. scalar rmse_WB4 = sqrt(sse_WB4 / cnt_WB4)

. scalar mape_WB4 = mape_WB4 / cnt_WB4

